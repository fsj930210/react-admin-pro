{
  "root": true,
  "extends": [
    "oxc:recommended",
    "oxc:react"
  ],
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "semi": ["error", "always"],
    "quotes": ["error", "double"],
    "no-console": "warn",
    "react/react-in-jsx-scope": "off"
  }
}