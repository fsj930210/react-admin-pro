{
	"name": "react-admin-pro",
	"private": true,
	"version": "1.0.0",
	"description": "A modern React admin dashboard monorepo with multiple app targets, shared components, and best practices",
	"scripts": {
		"dev": "turbo run dev",
		"dev:web": "turbo run dev  --filter=@rap/web-app",
		"dev:web-vite": "turbo run dev:vite",
		"preview": "turbo run preview",
		"preview:web": "turbo run dev --filter=@rap/web-app",
		"preview:web-vite": "turbo run preview:vite",
		"build": "turbo run build",
		"build:web": "turbo run dev --filter=@rap/web-app",
		"build:web-vite": "turbo run build:vite",
		"lint": "turbo run lint",
		"prepare": "husky"
	},
	"workspaces": [
		"apps/*",
		"packages/*",
		"packages/components/*",
		"config/*",
		"config/lint/*",
		"docs/*"
	],
	"keywords": [
		"react",
		"admin",
		"dashboard",
		"monorepo",
		"pnpm",
		"typescript",
		"tailwindcss",
		"vite",
		"rsbuild",
		"tanstack"
	],
	"author": "",
	"license": "ISC",
	"type": "module",
	"packageManager": "pnpm@11.5.2",
	"devDependencies": {
		"@rap/commitlint-config": "workspace:*",
		"@rap/oxc-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"commitlint": "catalog:",
		"husky": "catalog:",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"turbo": "catalog:",
		"typescript": "^6.0.3"
	}
}
