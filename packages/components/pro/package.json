{
  "name": "@rap/components-pro",
  "version": "0.0.1",
  "description": "High-level UI components for React Admin Pro built on top of base components",
  "keywords": [
    "admin-ui",
    "dashboard",
    "layouts",
    "react",
    "tailwindcss",
    "ui-components"
  ],
  "type": "module",
  "exports": {
    "./input": "./src/components/input/index.tsx",
    "./icon": "./src/components/icon/index.tsx",
    "./dialog": "./src/components/dialog/index.tsx",
    "./markdown": "./src/components/markdown/index.tsx",
    "./pagination": "./src/components/pagination/index.tsx",
    "./route-keep-alive": "./src/components/route-keep-alive/index.tsx",
    "./tree": "./src/components/tree/index.tsx"
  },
  "scripts": {
    "lint": "oxfmt --check -c ./oxfmt.config.ts . && oxlint -c ./oxlint.config.ts .",
    "lint:fix": "oxlint -c ./oxlint.config.ts . --fix && oxfmt --write -c ./oxfmt.config.ts ."
  },
  "dependencies": {
    "@dnd-kit/abstract": "catalog:",
