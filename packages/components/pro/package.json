    "@iconify-json/ri": "catalog:",
    "@iconify/react": "catalog:",
    "@rap/components-ui": "workspace:*",
    "@rap/hooks": "workspace:*",
    "@rap/utils": "workspace:*",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "class-variance-authority": "catalog:",
    "framer-motion": "catalog:",
    "highlight.js": "catalog:",
    "lucide-react": "catalog:",
    "react-markdown": "catalog:",
    "rehype-highlight": "catalog:",
    "rehype-raw": "catalog:",
    "rehype-sanitize": "catalog:",
    "remark-gfm": "catalog:"
  },
  "devDependencies": {
    "@rap/oxc-config": "workspace:*",
    "@rap/tailwindcss-config": "workspace:*",
    "@rap/tsconfig": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
