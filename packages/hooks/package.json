{
  "name": "@rap/hooks",
  "version": "0.0.1",
  "description": "Reusable React hooks for React Admin Pro",
  "keywords": [
    "react",
    "hooks",
    "custom-hooks",
    "react-hooks",
    "utility-hooks"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxfmt --check -c ./oxfmt.config.ts . && oxlint -c ./oxlint.config.ts .",
    "lint:fix": "oxlint -c ./oxlint.config.ts . --fix && oxfmt --write -c ./oxfmt.config.ts ."
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "devDependencies": {
    "@rap/oxc-config": "workspace:*",
    "@rap/tsconfig": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:"
  },
  "dependencies": {
    "@rap/utils": "workspace:*",
    "dayjs": "catalog:",
    "immer": "catalog:",
    "lodash-es": "catalog:",
    "zustand": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
