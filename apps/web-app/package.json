{
  "name": "@rap/web-app",
  "version": "0.0.1",
  "private": true,
  "description": "React Admin Pro SPA application built with Vite/Rsbuild, TanStack Router and React Query",
  "keywords": [
    "react",
    "vite",
    "rsbuild",
    "spa",
    "tanstack-router",
    "tanstack-query",
    "admin-dashboard",
    "tailwindcss"
  ],
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "preview": "rsbuild preview --env-mode preview",
    "dev:vite": "vite",
    "build:vite": "tsc -b && vite build",
    "preview:vite": "vite preview",
    "lint": "oxfmt --check -c ./oxfmt.config.ts . && oxlint -c ./oxlint.config.ts .",
    "lint:fix": "oxlint -c ./oxlint.config.ts . --fix && oxfmt --write -c ./oxfmt.config.ts ."
  },
  "devDependencies": {
    "@rap/oxc-config": "workspace:*",
    "@rap/rsbuild-config": "workspace:*",
    "@rap/tailwindcss-config": "workspace:*",
    "@rap/tsconfig": "workspace:*",
    "@rap/vite-config": "workspace:*",
    "@rsbuild/core": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "msw": "catalog:",
    "vite": "catalog:"
  },
  "dependencies": {
    "@bprogress/core": "catalog:",
    "@iconify-json/carbon": "catalog:",
    "@iconify-json/lucide": "catalog:",
    "@iconify-json/ri": "catalog:",
    "@iconify/react": "catalog:",
    "@rap/components-pro": "workspace:*",
    "@rap/components-ui": "workspace:*",
    "@rap/hooks": "workspace:*",
    "@rap/i18n": "workspace:*",
    "@rap/mock-config": "workspace:*",
    "@rap/styles": "workspace:*",
    "@rap/utils": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-table": "catalog:",
    "class-variance-authority": "catalog:",
    "dayjs": "catalog:",
    "echarts": "catalog:",
    "highlight.js": "catalog:",
    "lodash-es": "catalog:",
    "lucide-react": "catalog:",
    "overlayscrollbars": "catalog:",
    "pinyin-pro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "rehype-highlight": "catalog:",
    "rehype-raw": "catalog:",
    "remark-gfm": "catalog:",
    "sonner": "catalog:",
    "zod": "catalog:"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
