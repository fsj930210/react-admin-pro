{
	"name": "@rap/web-app",
	"version": "0.0.1",
	"private": true,
	"description": "React Admin Pro SPA application built with Vite/Rsbuild, TanStack Router and React Query",
	"keywords": [
		"react",
		"vite",
		"rsbuild",
		"spa",
		"tanstack-router",
		"tanstack-query",
		"admin-dashboard",
		"tailwindcss"
	],
	"type": "module",
	"scripts": {
		"build": "rsbuild build",
		"dev": "rsbuild dev",
		"preview": "rsbuild preview --env-mode preview",
		"dev:vite": "vite",
		"build:vite": "tsc -b && vite build",
		"preview:vite": "vite preview",
		"lint": ""
	},
